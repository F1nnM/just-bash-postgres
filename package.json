{
  "name": "just-bash-postgres",
  "version": "0.1.2",
  "description": "PostgreSQL filesystem provider for just-bash with ltree, FTS, vector search, and RLS",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "sql"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck"
  },
  "keywords": [
    "just-bash",
    "filesystem",
    "postgresql",
    "ltree",
    "vector-search",
    "full-text-search",
    "pgvector",
    "rls",
    "multi-tenant"
  ],
  "license": "MIT",
  "author": "Finn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/F1nnM/just-bash-postgres.git"
  },
  "homepage": "https://github.com/F1nnM/just-bash-postgres#readme",
  "bugs": {
    "url": "https://github.com/F1nnM/just-bash-postgres/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "just-bash": "^2.14.0"
  },
  "peerDependencies": {
    "just-bash": "^2.14.0"
  },
  "dependencies": {
    "postgres": "^3.4.8"
  }
}
